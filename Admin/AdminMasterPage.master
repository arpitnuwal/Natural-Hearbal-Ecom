</div>

        <asp:ContentPlaceHolder id="ContentPlaceHolder1" runat="server">
        
        </asp:ContentPlaceHolder>
    
        <footer>
  <div>© 2026 SPMPL Admin Panel. All Rights Reserved.</div>
  <div class="footer-links">
