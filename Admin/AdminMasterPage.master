    <a href="Categories.aspx"
       class="<%= ActiveClass("categories.aspx") %>">
       <i class="bi bi-tag"></i> Categories
    </a>

    <a href="SubCategories.aspx"
       class="<%= ActiveClass("subcategories.aspx") %>">
       <i class="bi bi-tags"></i> Sub Categories
    </a>

            <a href="Slider.aspx"
   class="<%= ActiveClass("slider.aspx") %>">
    <i class="bi bi-images"></i> Slider
</a>

    <a href="Brands.aspx"
       class="<%= ActiveClass("brands.aspx") %>">
       <i class="bi bi-award"></i> Brands
    </a>

    <a href="Products.aspx"
       class="<%= ActiveClass("products.aspx") %>">
       <i class="bi bi-box-seam"></i> Productsss
    </a>
           
               <a href="BannerManagement.aspx"
   class="<%= ActiveClass("bannermanagement.aspx") %>">
   <i class="bi bi-image"></i> Banners
</a>
             <a href="orderlist.aspx"
       class="<%= ActiveClass("orderlist.aspx") %>">
       <i class="bi bi-journal-text"></i> Order List
    </a>
  <a href="Reports.aspx"
       class="<%= ActiveClass("Reports.aspx") %>">
       <i class="bi bi-journal-text"></i> Sales Reports
    </a>
    <a href="Blog.aspx"
       class="<%= ActiveClass("blog.aspx") %>">
       <i class="bi bi-journal-text"></i> Blog
    </a>

    <a href="Testimonials.aspx"
       class="<%= ActiveClass("testimonials.aspx") %>">
